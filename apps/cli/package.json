{
    "name": "fluxo-cli",
    "version": "1.0.0",
    "description": "Fluxo management CLI",
    "private": true,
    "type": "module",
    "bin": {
        "fluxo": "./bin/cli.js"
    },
    "scripts": {
        "fluxo": "bun bin/cli.js",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "types": "tsc --noEmit"
    },
    "dependencies": {
        "@clack/prompts": "^0.10.1",
        "@fluxo/crypto": "workspace:*",
        "@fluxo/db": "workspace:*",
        "@fluxo/forge": "workspace:*",
        "@fluxo/logger": "workspace:*",
        "@fluxo/types": "workspace:*",
        "bcrypt": "^6.0.0",
        "boxen": "^8.0.1",
        "chalk": "^5.6.2",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@fluxo/eslint-config": "workspace:*",
        "@types/bcrypt": "^6.0.0",
        "@types/bun": "latest",
        "@types/node": "^25.9.4",
        "eslint": "^9.39.2",
        "typescript": "^5.9.3"
    }
}
