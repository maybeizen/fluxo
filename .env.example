# Environment
NODE_ENV=development

# This port is used ONLY for the API. The frontend will use port 5000 by default.
PORT=5001
FRONTEND_URL=http://localhost:5000
API_URL=http://localhost:5001
APP_NAME=Fluxo

# Security / auth
ENCRYPTION_KEY=your-32-byte-encryption-key-here
SESSION_SECRET=your-session-secret-here
SESSION_LIFETIME=604800
BCRYPT_ROUNDS=10
# COOKIE_DOMAIN=.example.com

# Database
POSTGRES_URL=postgresql://user:password@localhost:5432/fluxo

# Redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Email (optional)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=your-smtp-password
# EMAIL_FROM=noreply@example.com

# Discord OAuth
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=http://localhost:5001/api/v1/discord/callback

# Plugins (optional)
# PLUGINS_DIR=./plugins

# Frontend (client-inlined at build time)
NEXT_PUBLIC_API_URL=http://localhost:5001/api/v1
